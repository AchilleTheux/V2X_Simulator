<?xml version="1.0" encoding="UTF-8"?>
<!--
  Two single-lane edges with strict permissions to keep behavior simple:
  - e_car: only passenger vehicles
  - e_ped: only pedestrians
-->
<edges>
    <edge id="e_car" from="nW" to="nE" priority="1" numLanes="1" speed="13.89" allow="passenger"/>
    <edge id="e_ped" from="nS" to="nN" priority="1" numLanes="1" speed="1.40" allow="pedestrian"/>
</edges>
